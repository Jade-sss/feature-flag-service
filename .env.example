# ─────────────────────────────────────────────────────────────────────────────
# Feature Flag Service – Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────────────────────
ENV=development                          # development | staging | production
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/featureflags
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_ENABLED=true                         # set false for local dev (no key needed)
MASTER_API_KEY=                           # bootstrap admin key — set a strong secret

# ── Caching ───────────────────────────────────────────────────────────────────
CACHE_FLAG_TTL=300                        # seconds – flag data cache
CACHE_EVAL_TTL=60                         # seconds – evaluation result cache

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100                   # max requests per window per IP
RATE_LIMIT_WINDOW=60                      # sliding window in seconds

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_FORMAT=text                           # text | json (use json in production)
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=*                            # comma-separated origins, or * for all
ALLOWED_HOSTS=*                           # comma-separated hostnames, or * for all

# ── Database Pool ─────────────────────────────────────────────────────────────
DB_POOL_SIZE=10
DB_POOL_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600                      # seconds – recycle connections after 1 hour
